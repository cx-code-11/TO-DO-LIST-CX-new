# ── Database (AWS RDS PostgreSQL) ──────────────────────────────
# Format: postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/DB_NAME
DATABASE_URL="postgresql://postgres:yourpassword@your-rds-endpoint.rds.amazonaws.com:5432/pern_todo"

# ── App ─────────────────────────────────────────────────────────
PORT=4000

# ── Admin Token (generate with:) ────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN="change-me-to-a-long-random-secret"

# ── CORS (comma-separated allowed origins) ───────────────────────
ALLOWED_ORIGINS="https://acme.yourdomain.com,https://admin.yourdomain.com"

# ── Environment ──────────────────────────────────────────────────
NODE_ENV="production"
