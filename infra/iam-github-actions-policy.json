{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ClientApp",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::pern-todo-client-app",
        "arn:aws:s3:::pern-todo-client-app/*",
        "arn:aws:s3:::pern-todo-admin-dashboard",
        "arn:aws:s3:::pern-todo-admin-dashboard/*"
      ]
    },
    {
      "Sid": "CloudFrontInvalidation",
      "Effect": "Allow",
      "Action": [
        "cloudfront:CreateInvalidation",
        "cloudfront:GetDistribution",
        "cloudfront:GetInvalidation"
      ],
      "Resource": "*"
    }
  ]
}
